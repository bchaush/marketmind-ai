# .streamlit/secrets.toml.template
# Copy this to .streamlit/secrets.toml for local Streamlit Cloud testing, or paste values into the Streamlit Cloud secrets manager at share.streamlit.io → App settings → Secrets.
# Never commit secrets.toml to git.

GOOGLE_PLACES_API_KEY = "your-google-places-api-key"
CENSUS_API_KEY = "your-census-api-key"
ANTHROPIC_API_KEY = "your-anthropic-api-key"
DEV_MODE = "false"
CTA_MODE = "recruiter"  # Options: "recruiter" | "startup"
TELEMETRY_ENABLED = "false"  # Set to "true" after public URL is shared to audit search zones
