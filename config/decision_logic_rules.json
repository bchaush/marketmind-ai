  "status_assignment_rules": [
    {
      "rule_id": "STATUS_REJECTED_DESERT",
      "priority": 1000,
      "flag": "REJECTED_DESERT",
      "status": "NO-GO",
      "output_tags": ["POPULATION_NULL", "SCORING_ABORTED"]
    },
    {
      "rule_id": "STATUS_MONOPOLY_FORCE_CAUTION",
      "priority": 900,
      "flag": "CRITICAL_RISK_MONOPOLY_REVIEW_CONCENTRATION",
      "status": "CAUTION",
      "output_tags": ["MONOPOLY_CONCENTRATION", "ATTENTION_MARKET_CLOSED"]
    },
    {
      "rule_id": "STATUS_GOLDMINE_GO",
      "priority": 850,
      "flag": "GOLDMINE_ZERO_COMPETITORS",
      "status": "GO",
      "output_tags": ["FIRST_MOVER_WINDOW", "ZERO_COMPETITION"]
    },
    {
      "rule_id": "STATUS_DATA_DESERT_CAUTION",
      "priority": 800,
      "flag": "DATA_DESERT",
      "status": "CAUTION",
      "output_tags": ["DATA_INCOMPLETE", "CONFIDENCE_CAPPED"]
    },
    {
      "rule_id": "STATUS_HIGH_RISK_NO_GO",
      "priority": 300,
      "condition": { "risk_score": { "gte": 85 } },
      "status": "NO-GO",
      "output_tags": ["EXTREME_RISK", "CAPITAL_NOT_RECOMMENDED"]
    },
    {
      "rule_id": "STATUS_STRONG_GO",
      "priority": 200,
      "condition": {
        "demand_score": { "gte": 75 },
        "competition_pressure_score": { "lt": 50 },
        "risk_score": { "lt": 40 }
      },
      "status": "GO",
      "output_tags": ["STRONG_DEMAND", "LOW_PRESSURE", "LOW_RISK"]
    },
    {
      "rule_id": "STATUS_DEFAULT_CAUTION",
      "priority": 1,
      "condition": "default",
      "status": "CAUTION",
      "output_tags": ["DEFAULT_CAUTION"]
    }
  ],

  "trade_off_rules": [
    {
      "rule_id": "TRADEOFF_HIGH_DEMAND_HIGH_COMPETITION",
      "priority": 80,
      "condition": {
        "demand_score": { "gte": 70 },
        "competition_pressure_score": { "gte": 70 }
      },
      "output_tags": ["HIGH_DEMAND", "EXTREME_COMPETITION", "NICHE_POSITIONING_REQUIRED"]
    },
    {
      "rule_id": "TRADEOFF_LOW_DEMAND_LOW_COMPETITION",
      "priority": 60,
      "condition": {
        "demand_score": { "lt": 45 },
        "competition_pressure_score": { "lt": 45 }
      },
      "output_tags": ["WEAK_DEMAND", "LOW_COMPETITION", "MARKET_UNDERSIZED"]
    },
    {
      "rule_id": "TRADEOFF_HIGH_RISK_LOW_CONFIDENCE",
      "priority": 90,
      "condition": {
        "risk_score": { "gte": 75 },
        "confidence_score": { "lt": 55 }
      },
      "output_tags": ["HIGH_RISK", "LOW_CONFIDENCE", "RECOMMENDATION_INTEGRITY_COMPROMISED"]
    },
    {
      "rule_id": "TRADEOFF_STRONG_GAP_HIGH_COMPETITION",
      "priority": 70,
      "condition": {
        "market_gap_score": { "gte": 65 },
        "competition_pressure_score": { "gte": 70 }
      },
      "output_tags": ["MARKET_GAP_EXISTS", "COMPETITION_ENTRENCHED", "SPEED_TO_MARKET_CRITICAL"]
    }
